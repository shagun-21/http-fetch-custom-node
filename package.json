{
  "name": "n8n-nodes-google-maps-fetch",
  "version": "0.1.1",
  "description": "n8n node that fetches Google Maps search HTML with browser-like fingerprint and cookie capture (NID, CONSENT, SOCS, AEC)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "google-maps",
    "scraping",
    "cookies",
    "nid"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "Akhilesh Chitlangia"
  },
  "main": "index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/GoogleMapsFetch/GoogleMapsFetch.node.js"
    ]
  },
  "dependencies": {
    "got-scraping": "^4.0.6",
    "tough-cookie": "^4.1.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "n8n-workflow": "^1.82.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "@types/tough-cookie": "^4.0.5"
  }
}